APP_NAME="Aspha CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Sanctum SPA auth (dev). En prod: SANCTUM_STATEFUL_DOMAINS=app.aspha.fr et SESSION_DOMAIN=.aspha.fr si front et back sur sous-domaines partageant le domaine racine.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev: SQLite. Prod o2switch: MySQL/MariaDB
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=aspha_crm
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@aspha.local"
MAIL_FROM_NAME="${APP_NAME}"

# Google Maps (Distance Matrix pour calculs de trajet)
GOOGLE_MAPS_API_KEY=

VITE_APP_NAME="${APP_NAME}"
