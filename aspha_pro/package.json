{
  "name": "aspha-pro",
  "version": "0.1.0",
  "private": true,
  "description": "Aspha Pro — CRM métier services à la personne. Backend Laravel 11 + Frontend React/Vite.",
  "scripts": {
    "install:all": "npm --prefix frontend install && composer --working-dir=backend install",
    "dev": "concurrently --names \"BACK,FRONT\" --prefix-colors \"magenta.bold,cyan.bold\" \"npm:dev:back\" \"npm:dev:front\"",
    "dev:back": "php backend/artisan serve --host=127.0.0.1 --port=8000",
    "dev:front": "npm --prefix frontend run dev -- --host 127.0.0.1",
    "build:front": "npm --prefix frontend run build",
    "fresh": "php backend/artisan migrate:fresh --seed",
    "test:back": "php backend/artisan test",
    "lint:front": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
