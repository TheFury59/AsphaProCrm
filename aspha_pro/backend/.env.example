# ============================================================================
# .env.example — TEMPLATE DE DÉVELOPPEMENT LOCAL UNIQUEMENT
# ============================================================================
# ⚠️ POUR LA PRODUCTION, utilise `deploy/.env.o2switch.template` qui contient
#    les valeurs durcies (APP_DEBUG=false, LOG_LEVEL=warning,
#    SESSION_SECURE_COOKIE=true, etc.). NE PAS copier ce fichier en prod.
# ============================================================================
APP_NAME="Aspha Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Sanctum SPA — domains autorisés pour l'auth cookie
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:3000,127.0.0.1:3000

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# BDD locale : SQLite. Prod o2switch : MariaDB.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=aspha_pro
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@aspha.fr"
MAIL_FROM_NAME="${APP_NAME}"

# Intégrations externes
GOOGLE_MAPS_API_KEY=
PENNYLANE_API_KEY=
PENNYLANE_API_URL=https://app.pennylane.com/api/external/v1

# Rate limiting
# RATE_LIMIT_LOGIN=3 recommandé en prod pour limiter le brute-force.
# 5 en dev pour ne pas se faire bloquer pendant les tests d'auth.
RATE_LIMIT_API=60
RATE_LIMIT_LOGIN=5

VITE_APP_NAME="${APP_NAME}"
