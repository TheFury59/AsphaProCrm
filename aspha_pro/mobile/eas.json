{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://asphapro-erp.fr/api/v1"
      }
    },
    "preprod": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "preprod",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://preprod.asphapro-erp.fr/api/v1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://asphapro-erp.fr/api/v1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": ""
      }
    }
  }
}
