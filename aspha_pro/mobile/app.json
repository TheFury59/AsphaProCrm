{
  "expo": {
    "name": "Aspha Pro",
    "slug": "aspha-pro",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aspha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/logo-aspha.png",
    "splash": {
      "image": "./assets/logo-aspha.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.asphapro.mobile"
    },
    "android": {
      "package": "fr.asphapro.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-aspha.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#dc2626"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Aspha Pro utilise la caméra pour scanner les QR codes de badgeage sur les sites d'intervention."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aspha Pro utilise votre position pour valider votre présence sur le site d'intervention."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aspha Pro a besoin d'accéder à vos photos pour mettre à jour votre photo de profil.",
          "cameraPermission": "Aspha Pro a besoin d'accéder à la caméra pour prendre une photo de profil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://asphapro-erp.fr/api/v1",
      "router": {},
      "eas": {
        "projectId": "ddb446c7-e22f-46a8-9804-fb8abca9ab4f"
      }
    },
    "owner": "himelys-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ddb446c7-e22f-46a8-9804-fb8abca9ab4f"
    }
  }
}
