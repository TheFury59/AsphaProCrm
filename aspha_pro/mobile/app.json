{
  "expo": {
    "name": "Aspha Pro",
    "slug": "aspha-pro",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aspha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.asphapro.mobile"
    },
    "android": {
      "package": "fr.asphapro.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#dc2626"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Aspha Pro utilise la caméra pour scanner les QR codes de badgeage sur les sites d'intervention."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aspha Pro utilise votre position pour valider votre présence sur le site d'intervention."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://asphapro-erp.fr/api/v1"
    }
  }
}
