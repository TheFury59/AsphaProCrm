{
  "expo": {
    "name": "Aspha Pro",
    "slug": "aspha-pro",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aspha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.asphapro.mobile"
    },
    "android": {
      "package": "fr.asphapro.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://asphapro-erp.fr/api/v1"
    }
  }
}
